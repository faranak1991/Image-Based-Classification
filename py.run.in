#!/bin/bash
#SBATCH --job-name=py1000_gpu
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=8
#SBATCH --mem=64G
#SBATCH --time=172:00:00
#SBATCH --gres=gpu:1                    # request one GPU
#SBATCH --output=out.log
#SBATCH --error=err.log
#SBATCH --export=ALL

module purge
module load CUDA/11.1.1-GCC-10.2.0      # only if this matches the cluster’s driver + your torch build
# module load your-cluster-pytorch      # if your cluster provides it

source ~/.bashrc
conda activate ml_env

python -u - <<'PY'
import torch, os
print("torch:", torch.__version__)
print("torch cuda build:", torch.version.cuda)
print("CUDA_VISIBLE_DEVICES:", os.environ.get("CUDA_VISIBLE_DEVICES"))
print("cuda available:", torch.cuda.is_available(), "count:", torch.cuda.device_count())
if torch.cuda.is_available():
    print("gpu:", torch.cuda.get_device_name(0))
else:
    raise SystemExit("ERROR: No GPU visible to this job.")
PY

python -u 2-second-Scenario-CLAHE2.py
